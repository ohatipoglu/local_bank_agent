# Local Bank AI Agent - Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Application
# =============================================================================
APP_NAME=Local Bank AI Agent
DEBUG=false
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Security & CORS
# =============================================================================
API_KEY=  # Optional: Set to protect API endpoints
CORS_ORIGINS=*  # Comma-separated list of allowed origins, or * for all
ALLOWED_HOSTS=*  # Comma-separated list of allowed hosts

# CRITICAL: JWT Secret for production (use strong random string, min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-production-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# =============================================================================
# Google Cloud TTS (CRITICAL: Never commit this file to version control)
# =============================================================================
GOOGLE_APPLICATION_CREDENTIALS=./local-bank-tts-424c208f9a50.json

# =============================================================================
# LLM Settings (Ollama - Primary)
# =============================================================================
LLM_MODEL_NAME=gemma4:26B-32K
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1536

# =============================================================================
# LLM Settings (OpenAI - Fallback)
# =============================================================================
# Uncomment and set your API key to enable OpenAI fallback
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SECONDS=30
# OPENAI_MAX_TOKENS=1536

# =============================================================================
# STT Settings (Faster-Whisper)
# =============================================================================
STT_MODEL_SIZE=large-v3
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=tr

# =============================================================================
# TTS Settings
# =============================================================================
TTS_LANGUAGE_CODE=tr-TR
TTS_VOICE_NAME=tr-TR-Wavenet-D
TTS_MAX_RETRIES=2
TTS_TIMEOUT_SECONDS=30.0
TTS_ENABLE_PIPER_FALLBACK=true
PIPER_MODEL_PATH=./models/tr_TR-dfki-medium.onnx

# Coqui XTTS v2 (local, high-quality Turkish TTS with GPU support)
# Note: Requires manual installation - see COQUI_INSTALL_GUIDE.md
TTS_ENABLE_COQUI_FALLBACK=false
COQUI_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
COQUI_VOICE_REF_AUDIO=./models/coqui_reference.wav
COQUI_SPEAKER_WAV=
COQUI_USE_GPU=true

# Edge TTS (Microsoft Edge online TTS, free, no API key, requires internet)
TTS_ENABLE_EDGE_FALLBACK=true
EDGE_TTS_VOICE=tr-TR-AhmetNeural

# =============================================================================
# Security
# =============================================================================
MAX_AUDIO_SIZE_MB=10
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Input sanitization
MAX_INPUT_LENGTH=1000

# =============================================================================
# Session Management
# =============================================================================
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=10000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG
LOG_JSON_FORMAT=false

# =============================================================================
# Monitoring & Metrics (Prometheus)
# =============================================================================
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# =============================================================================
# Audio Processing
# =============================================================================
# Async processing settings
AUDIO_PROCESSING_TIMEOUT_SECONDS=120
ENABLE_ASYNC_PROCESSING=true
